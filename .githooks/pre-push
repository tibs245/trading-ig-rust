#!/usr/bin/env bash
# pre-push hook: run the full test suite + a security audit before pushing.
# Activate once after cloning with: `git config core.hooksPath .githooks`
#
# Skip with: `git push --no-verify` (e.g. for documentation-only branches).

set -euo pipefail

# Tag <-> crate version consistency: pushing tag vX.Y.Z requires Cargo.toml
# at the tagged commit to declare version = "X.Y.Z". History: tags were
# repeatedly cut without bumping Cargo.toml (v0.1.4 shipped as "0.1.3").
while read -r _local_ref local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    refs/tags/v*)
      [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue # deletion
      tag_version="${remote_ref#refs/tags/v}"
      crate_version=$(git show "$local_sha:Cargo.toml" 2>/dev/null | sed -n 's/^version = "\(.*\)"/\1/p' | head -1)
      if [ "$crate_version" != "$tag_version" ]; then
        echo "pre-push: REFUSED tag v$tag_version — Cargo.toml at tagged commit declares version \"$crate_version\"" >&2
        echo "pre-push: bump Cargo.toml (+ Cargo.lock), commit, re-tag. (--no-verify to override.)" >&2
        exit 1
      fi
      echo "pre-push: tag v$tag_version == Cargo.toml version — OK"
      ;;
  esac
done < /dev/stdin

echo "pre-push: cargo test --all-targets --all-features"
cargo test --all-targets --all-features

# cargo-audit catches new RustSec advisories before they hit the remote
# CI. We ignore RUSTSEC-2023-0071 (rsa crate Marvin attack on PKCS#1v15
# decryption — we only encrypt, not vulnerable; see SECURITY.md for the
# full justification).
#
# Skip if cargo-audit isn't installed locally — don't block contributors
# who haven't run `cargo install cargo-audit` yet. CI runs it
# unconditionally.
if command -v cargo-audit > /dev/null 2>&1; then
  echo "pre-push: cargo audit"
  cargo audit --deny warnings --ignore RUSTSEC-2023-0071
else
  echo "pre-push: cargo-audit not installed locally — skipping (run 'cargo install cargo-audit' to enable)"
fi

echo "pre-push: OK"
